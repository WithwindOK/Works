		lineageTag: 8f4c7088-0db8-4f4e-8a60-56c34fd52a56

	/// 公式：SUM('F_下游合同完成量'[价税合计])/[_货币系数]
	measure 'sum.下游合同完成量.价税合计' = SUM('F_下游合同完成量'[价税合计])/[_货币系数]
		formatString: #,0.00
		displayFolder: 合计
		lineageTag: 6a6c4818-7da0-4da3-ab34-56fc54b5befb

	/// 公式：
	/// VAR _Maxt=MAX('D_日历'[日期])
	/// VAR _KLJS=CALCULATE([sum.下游合同结算.价税合计],'D_日历'[日期]<=_Maxt)  //开累结算
	/// VAR _KLWCL=CALCULATE([sum.下游合同完成量.价税合计],'D_日历'[日期]<=_Maxt) //开累完成量
	/// RETURN
	/// COALESCE(_KLJS,_KLWCL)
	/// 
	measure '_下游合同应付.价税合计.Exp' = ```
			
			VAR _Maxt=MAX('D_日历'[日期])
			VAR _KLJS=CALCULATE([sum.下游合同结算.价税合计],'D_日历'[日期]<=_Maxt)  //开累结算
			VAR _KLWCL=CALCULATE([sum.下游合同完成量.价税合计],'D_日历'[日期]<=_Maxt) //开累完成量
			RETURN
			COALESCE(_KLJS,_KLWCL)
			
			```
		displayFolder: 中间变量，不可直接用
		lineageTag: d7d4bb3c-25ff-4f3e-a6b3-aab0a13cbf60

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	/// 公式：IF(ISBLANK([sum.下游合同结算.价税合计]),"未结","已结")
	measure 'txt.是否已结' = IF(ISBLANK([sum.下游合同结算.价税合计]),"未结","已结")
		lineageTag: 2dc323d1-be01-48c1-8c0c-d190b5b8cd25

	/// 公式：SUMX(VALUES('D_下游合同'[KEYID]),[_下游合同应付.价税合计.Exp])
	measure 'cum.下游合同累计应付.价税合计' = SUMX(VALUES('D_下游合同'[KEYID]),[_下游合同应付.价税合计.Exp])
		formatString: #,0.00
		displayFolder: 合计
		lineageTag: d7878f28-ffed-42d1-b541-d8fa4531de1b

	/// 公式：CALCULATE([sum.下游合同额.价税合计],'F_下游合同评审'[合同版本]="初始合同")
	measure 'sum.下游合同额.价税合计.初始' = CALCULATE([sum.下游合同额.价税合计],'F_下游合同评审'[合同版本]="初始合同")
		formatString: #,0.00
		displayFolder: 合计
		lineageTag: 9560c06b-e869-41a2-b780-dbd46b32ddaf

	/// 公式：CALCULATE([sum.下游合同额.价税合计],'F_下游合同评审'[合同版本]="补充合同")
	measure 'sum.下游合同额.价税合计.补充' = CALCULATE([sum.下游合同额.价税合计],'F_下游合同评审'[合同版本]="补充合同")
		formatString: #,0.00
		displayFolder: 合计
		lineageTag: 041b40a2-f6bb-44df-87f3-ec933fdbc946

	/// 公式：CALCULATE(SUM('F_下游合同付款'[本期实际付款]),'F_下游合同付款'[评审状态]="已完成")/[_货币系数]
	measure 'sum.下游合同付款.实付' = CALCULATE(SUM('F_下游合同付款'[本期实际付款]),'F_下游合同付款'[评审状态]="已完成")/[_货币系数]
		formatString: #,0.00
		displayFolder: 合计
		lineageTag: 2181cc7b-38c4-44ff-83e1-f5ceb41c8552

	/// 公式：CALCULATE(SUM('F_下游合同付款'[本期实际付款]),'F_下游合同付款'[评审状态]="在途")/[_货币系数]
	measure 'sum.下游合同付款.在途' = CALCULATE(SUM('F_下游合同付款'[本期实际付款]),'F_下游合同付款'[评审状态]="在途")/[_货币系数]
		formatString: #,0.00
		displayFolder: 合计
		lineageTag: 2fad9df3-3fbb-4f2b-a6a5-e10c12d9b7dd

	/// 公式：
	/// VAR _Maxt=MAX('D_日历'[日期])
	/// VAR _KLFK=CALCULATE([sum.下游合同付款.实付],FILTER(ALL('D_日历'),'D_日历'[日期]<=_Maxt))  //开累付款
	/// RETURN
	/// _KLFK
	measure 'cum.下游合同付款.累计' =
			
			VAR _Maxt=MAX('D_日历'[日期])
			VAR _KLFK=CALCULATE([sum.下游合同付款.实付],FILTER(ALL('D_日历'),'D_日历'[日期]<=_Maxt))  //开累付款
			RETURN
			_KLFK
		formatString: #,0.00
		displayFolder: 合计
		lineageTag: 7b975a0c-df86-4262-a06f-492f84225ab7

	/// 公式：SUMX(VALUES('D_下游合同'[KEYID]),[cum.下游合同累计应付.价税合计]- [cum.下游合同付款.累计])
	measure 'cum.下游合同欠款.累计' = SUMX(VALUES('D_下游合同'[KEYID]),[cum.下游合同累计应付.价税合计]- [cum.下游合同付款.累计])
		formatString: #,0.00
		displayFolder: 合计
		lineageTag: 1c419b15-b1af-479b-b70c-e0ba446d476d

