	/// 公式：
	/// VAR _s=[sum.下游合同结算.价税合计]-[sum.下游合同完成量.价税合计]
	/// VAR _R=IF(_s<0,_s)
	/// RETURN
	/// _R
	measure _结算-完成量 =
			
			VAR _s=[sum.下游合同结算.价税合计]-[sum.下游合同完成量.价税合计]
			VAR _R=IF(_s<0,_s)
			RETURN
			_R
		formatString: 0
		displayFolder: 中间变量，不可直接用
		lineageTag: 51ccf242-eb42-4522-bacd-23f83ffdc3e3

