	/// 公式：SUM('F_下游合同评审'[价税合计])/[_货币系数]
	measure 'sum.下游合同额.价税合计' = SUM('F_下游合同评审'[价税合计])/[_货币系数]
		formatString: #,0.00
		displayFolder: 合计
		lineageTag: e0ca276e-d94a-4770-99ec-4abfb6798ae9

	/// 公式：SUM('F_下游合同结算'[价税合计])/[_货币系数]
	measure 'sum.下游合同结算.价税合计' = SUM('F_下游合同结算'[价税合计])/[_货币系数]
		formatString: #,0.00
