	partition D_下游合同 = m
		mode: import
		queryGroup: 下游合同\合同组\合同维度
		source =
				let
				    源 = Table.Combine({D_物资合同_L1, D_分包合同_L1}),
				    删除的副本 = Table.Distinct(源, {"KEYID"}),
				    已添加自定义 = Table.AddColumn(删除的副本, "合同KEY", each [合同编号]&"@"&[项目编码],type text),
				    #"重命名的列（兼容旧模型）" = Table.RenameColumns(已添加自定义,{{"合同类型", "分包类型"}})
				in
				    #"重命名的列（兼容旧模型）"

	changedProperty = IsHidden

	annotation PBI_ResultType = Table

	annotation PBI_NavigationStepName = 导航

